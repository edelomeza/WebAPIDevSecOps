# === Entorno ===
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080

# === Base de datos ===
# Connection string SIN UserID/Password (se pasan por DB_USER / DB_PASSWORD)
ConnectionStrings__DefaultConnection=Server=host;Database=db;Encrypt=True;TrustServerCertificate=True
DB_USER=usuario
DB_PASSWORD=contraseña

# === JWT ===
Jwt__Key=base64_32_bytes
Jwt__Issuer=https://tu-app.ondigitalocean.app
Jwt__Audience=https://tu-app.ondigitalocean.app

# === Otros ===
UseInMemoryDatabase=false
Cors__AllowedOrigin=https://tu-app.ondigitalocean.app
